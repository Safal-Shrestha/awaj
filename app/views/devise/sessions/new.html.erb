<div class="max-w-sm mx-auto px-4 py-16">
  <h2 class="text-2xl font-bold text-brand mb-6">Log in</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="field mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-zinc-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand" %>
    </div>

    <div class="field mb-4">
      <%= f.label :password, class: "block text-sm font-medium text-zinc-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="field mb-6 flex items-center gap-2">
        <%= f.check_box :remember_me, class: "rounded border-zinc-300 text-brand focus:ring-brand" %>
        <%= f.label :remember_me, class: "text-sm text-zinc-600" %>
      </div>
    <% end %>

    <div class="actions">
      <%= f.submit "Log in",
            class: "w-full bg-brand text-white text-sm font-medium py-2 rounded-md hover:bg-brand-light transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-sm text-zinc-500 [&_a]:text-brand [&_a]:hover:underline">
    <%= render "devise/shared/links" %>
  </div>
</div>