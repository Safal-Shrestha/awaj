<%= form_with(model: department) do |form| %>
  <% if department.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(department.errors.count, "error") %> prohibited this department from being saved:</h2>

      <ul>
        <% department.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <p><%= form.label :department_name %><br /></p>
    <p><%= form.text_field :department_name, autofocus: true, autocomplete: "department_name" %></p>
  </div>

  <div class="field">
    <p><%= form.label :slug %><br /></p>
    <p><%= form.text_field :slug, autofocus: true, autocomplete: "slug" %></p>
  </div>

  <div class="field">
    <p><%= form.label :description %><br /></p>
    <p><%= form.text_field :description, autofocus: true, autocomplete: "description" %></p>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
