<%= form_with model: issue, local: true, data: { controller: "department-category" } do |f| %>
  <div class="field mb-4">
    <%= f.label :title, class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :title,
          class: "w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand" %>
  </div>

  <div class="field mb-4">
    <%= f.label :description, class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_area :description, rows: 5,
          class: "w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand" %>
  </div>

  <div class="field mb-4">
    <%= label_tag :department_filter, "Department", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= select_tag :department_filter,
          options_from_collection_for_select(@departments, :id, :department_name),
          { include_blank: "Select a department",
            data: { "department-category-target": "department", action: "change->department-category#filter" },
            class: "w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand bg-white" } %>
  </div>

  <div class="field mb-4">
    <%= f.label :category_id, "Category", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.select :category_id,
          options_for_select(@categories.map { |c| [c.name, c.id, { data: { department_id: c.department_id } }] }),
          { include_blank: "Select a department first" },
          { data: { "department-category-target": "category" }, disabled: true,
            class: "w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand bg-white disabled:bg-zinc-50 disabled:text-zinc-400" } %>
  </div>

  <div class="field mb-6 flex items-center gap-2">
    <%= f.check_box :anonymous, class: "rounded border-zinc-300 text-brand focus:ring-brand" %>
    <%= f.label :anonymous, "Report anonymously", class: "text-sm text-zinc-600" %>
  </div>

  <%= f.submit "Report Issue",
        class: "w-full bg-brand text-white text-sm font-medium py-2 rounded-md hover:bg-brand-light transition-colors cursor-pointer" %>
<% end %>