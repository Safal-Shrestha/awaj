<h1>Issues</h1>

<% if policy(Issue).create? %>
  <%= link_to "Report an Issue", new_issue_path, class: "btn-primary" %>
<% end %>

<ul>
  <% @issues.each do |issue| %>
    <li>
      <%= link_to issue.title, issue %>
      <%= issue.status.humanize %>
      <%= render "votes/vote_button", issue: issue, voted: @voted_issue_ids.include?(issue.id) %>
    </li>
  <% end %>
</ul>